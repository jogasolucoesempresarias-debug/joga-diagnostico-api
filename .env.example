# ─── IA ───────────────────────────────────────────────────────────────
# Em dev/teste, reusar a chave do projeto "Tabela Auditoria" (.env de lá).
OPENAI_API_KEY=

# ─── Banco (Postgres) ─────────────────────────────────────────────────
# Dev: Postgres local. Prod: postgres_postgres / joga_diagnostico no Swarm.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/joga_diagnostico

# ─── WhatsApp (UazAPI) — reusar instância DanfeZap/Rizza ──────────────
UAZAPI_URL=https://free.uazapi.com
UAZAPI_TOKEN=

# ─── E-mail (Resend) — remetente já verificado no domínio da JOGA ─────
RESEND_API_KEY=
RESEND_FROM=joga@jogasolucoes.com.br

# ─── Destinatários do pré-brief (João + equipe) ───────────────────────
JOAO_WHATSAPP=5528999920221
PREBRIEF_EMAILS=joga@jogasolucoes.com.br,jjvictorep@gmail.com,ggabriel.milho@gmail.com

# ─── CORS (dev: front Next em :3000) ──────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Flag de envio ────────────────────────────────────────────────────
# false = NÃO dispara WhatsApp/e-mail real, apenas loga (modo dev).
ENVIO_ATIVO=false

TZ=America/Sao_Paulo

# E-mail de 'recebido' pro cliente (Resend). true = liga (independe da UazAPI).
AVISO_CLIENTE_ATIVO=true
